# Basic Makefile for static or shared C library

# Compiler and archiver
CC = @CC@
LIBS=@LIBS@
LDFLAGS=@LDFLAGS@
# Directories
SRC_DIR = src
OUT_DIR = out
OBJ_DIR=$(OUT_DIR)/obj
ASM_DIR=$(OUT_DIR)/asm
INCLUDE_DIR = include
prefix=@prefix@
exec_prefix=@exec_prefix@
bindir=@bindir@
INSTALL=@INSTALL@
EXECUTABLE_BASENAME = @PACKAGE_NAME@
WASM_DIR=$(SRC_DIR)/wasm


SRC_EXTENSION=c
OBJ_EXTENSION=o
ASM_EXTENSION=s
SRCS =$(wildcard $(SRC_DIR)/*.$(SRC_EXTENSION))
ASMS=$(SRCS:$(SRC_DIR)/%.$(SRC_EXTENSION)=$(ASM_DIR)/%.$(ASM_EXTENSION))
OBJS=$(ASMS:$(ASM_DIR)/%.$(ASM_EXTENSION)=$(OBJ_DIR)/%.$(OBJ_EXTENSION))
EXECUTABLE_DESTINATION=$(OUT_DIR)/$(EXECUTABLE_BASENAME)



VALGRIND_FLAGS=--leak-check=full
CFLAGS =-O3 -Wall -Wextra -I$(INCLUDE_DIR)
ASM_FLAGS=-masm=intel -fverbose-asm -fno-stack-protector -fno-asynchronous-unwind-tables -fno-ident


ifneq ($(or $(EMSCRIPTEN),$(findstring emcc,$(CC))),)
EXECUTABLE_BASENAME = index.html
SHELL_FILES = $(wildcard $(WASM_DIR)/*)
ASM_FLAGS = -fverbose-asm -fno-stack-protector -fno-asynchronous-unwind-tables -fno-ident
LDFLAGS += --shell-file $(WASM_DIR)/shell.html
endif

all: $(ASM_DIR) $(OBJ_DIR) $(EXECUTABLE_DESTINATION)

$(EXECUTABLE_DESTINATION): $(OBJS) $(SHELL_FILES)
	$(CC) $(CFLAGS) $(OBJS) $(LDFLAGS) -o $@ $(LIBS)

$(OBJ_DIR)/%.$(OBJ_EXTENSION) : $(ASM_DIR)/%.$(ASM_EXTENSION)
	$(CC) -c $< -o $@

$(ASM_DIR)/%.$(ASM_EXTENSION) : $(SRC_DIR)/%.$(SRC_EXTENSION)
	$(CC) $(CFLAGS) $(ASM_FLAGS) -S $< -o $@ $(LIBS)

$(OBJ_DIR):
	mkdir -p $(OBJ_DIR)

$(ASM_DIR):
	mkdir -p $(ASM_DIR)



valgrind:
	valgrind $(VALGRIND_FLAGS) $(EXECUTABLE_DESTINATION)

gdb:
	gdb ./$(EXECUTABLE_DESTINATION)

run:
	./$(EXECUTABLE_DESTINATION)

install:
	$(INSTALL) -Dm755 $(EXECUTABLE_DESTINATION) $(DESTDIR)$(bindir)/$(EXECUTABLE_BASENAME)

uninstall:
	rm -f $(DESTDIR)$(bindir)/$(EXECUTABLE_BASENAME)

# Clean up
clean:
	rm -rf $(OUT_DIR)
	rm -rf autom4te.cache
	rm a.wasm
	rm configure~

# Phony targets
.PHONY: all clean valgrind install uninstall gdb
.SECONDARY: $(ASMS)
